import stdlib::{io, net, time};

@MetaType(targets = [ MetaTarget.Function ])
type Get {
    path: String
}

// Apenas para exemplo, ignore funcionalidade
type HashMap[K, V] {
    elements: List[V],
    keys: List[K],
}

impl[K, V] HashMap[K, V]!? {

}

// Permite usar map["foo"]
impl[V] Index[V?] for HashMap[K, V] {
    fn get(self, index: K) -> V? { ... }
}

// Descreve limites concedidos à função, efeitos causam possível bloqueamento de thread ou processo
effect CustomEffect { io, time, net }


let handlers = HashMap[HttpMethod, fn(HttpRequest) -> String]::new();

fn registerHandler(handler: fn(HttpRequest) -> String) -> Void {
    if handler.getMeta(Get) != Null {
        handlers.add(HttpMethod.GET, handler);
    }

    //... other checks
}

@Get(path = "/users")
fn customGet(req: HttpRequest) -> String with { net } {
    ...
}

fn main() -> Int! with CustomEffect {
    let map: HashMap[String, Int] = HashMap::new()

    if map["foo"] != Null {
        try io.Println("Hello World");
    } elif map["bar"] == Null {
        try time.Sleep(2);
    }

    let result = net.MakeHttpRequest(HttpMethod.GET, "https://google.com") catch "Bye World";
}
