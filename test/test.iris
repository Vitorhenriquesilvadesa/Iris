import Iris.Data as df
import Iris.Stats exposing (sum, count)

model LinearModel {
    coefficients
    residuals
    r_squared

    plot() {

    }
}

model DataFrame {
    columns
    rows

    filter(predicate) {}
    take(limit) {}
    mutate(column, action) {}

    __slice__(begin, end) {
        rows[begin..end]
    }
}

extend DataFrame {
    plot() {

    }
}

let mean = (vec) -> (vec |> sum) / (vec |> count)

let myCustomFilter = (data, limit) -> {
    data
    |> filter(x -> x.label == "dog")
    |> filter((x) -> x.age > 2)
    |> take(limit)
}

let raw_data = df.read_csv("myFile.csv")
let filtered = raw_data |> myCustomFilter(5)
let age_mean = filtered.age |> mean

print(age_mean)

